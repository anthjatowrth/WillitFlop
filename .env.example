# ── Base de données Supabase (Direct Connection, port 5432) ───────────────────
DB_HOST=aws-0-xx-xxx-x.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.<project-ref>
DB_PASSWORD=your_supabase_password

# ── APIs externes ──────────────────────────────────────────────────────────────
STEAM_API_KEY=your_steam_api_key

TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# ── Prefect Cloud ──────────────────────────────────────────────────────────────
# Obtenir sur : https://app.prefect.cloud/my/api-keys
PREFECT_API_KEY=pnu_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Format : https://api.prefect.cloud/api/accounts/<account-id>/workspaces/<workspace-id>
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/xxx/workspaces/xxx
